#!/bin/sh
# pre-push guard: block pushes that change shell files without bumping the
# app version (version.js, CalVer). The actual check lives in
# tools/check-version-guard.sh, shared with CI so the two can't drift.
#
# One-time setup per clone:  git config core.hooksPath tools/hooks
# Deliberate bypass:         git push --no-verify

ZERO=0000000000000000000000000000000000000000

while read local_ref local_sha remote_ref remote_sha; do
  # branch deletion: nothing to check
  [ "$local_sha" = "$ZERO" ] && continue
  # new branch on the remote: no base to diff against, skip
  [ "$remote_sha" = "$ZERO" ] && continue

  sh tools/check-version-guard.sh "$remote_sha" "$local_sha" || exit 1
done

exit 0
